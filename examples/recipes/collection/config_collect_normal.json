{
    "project": "./",
    "uq_select_scheme": "tangent_lo",
    "testing_dir": "test_val",
    "results_prefix": "results",
    "desc_dir": "./desc_pool",
    "testdata_dir": "./other_dpdata",
    
    "fig_dpi": 300,
    "root_savedir": "dpeva_post_normal",

    "uq_trust_mode": "auto",
    "uq_trust_ratio": 0.50,
    "uq_trust_width": 0.15,
    
    "sampler_type": "direct",
    "direct_n_clusters": 1000,
    "direct_k": 1,
    "direct_thr_init": 0.1,

    "submission": {
        "backend": "slurm",
        "env_setup": [],
        "slurm_config": {
            "partition": "CPU-MISC",
            "qos": "rush-cpu",
            "ntasks": 1,
            "cpus_per_task": 4,
            "job_name": "DPEVA-collect"
        }
    }
}
