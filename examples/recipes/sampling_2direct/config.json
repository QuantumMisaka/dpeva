{
    "project": "./",
    "uq_select_scheme": "tangent_lo",
    "testing_dir": "test_results",
    "results_prefix": "results",
    "desc_dir": "./desc_pool",
    "testdata_dir": "./other_dpdata",
    
    "fig_dpi": 300,
    "root_savedir": "dpeva_sampling_2direct",

    "uq_trust_mode": "no_filter",
    
    "sampler_type": "2-direct",
    
    "step1_n_clusters": 10,
    "step1_threshold": 0.5,
    
    "step2_n_clusters": 20,
    "step2_threshold": 0.1,
    "step2_k": 1,
    "step2_selection": "smallest",

    "submission": {
        "backend": "slurm",
        "env_setup": [
            "source /opt/envs/deepmd3.1.2.env",
            "export DP_INTERFACE_PREC=high"
        ],
        "slurm_config": {
            "partition": "CPU-MISC",
            "qos": "rush-cpu",
            "ntasks": 1,
            "cpus_per_task": 4,
            "job_name": "DPEVA-collect"
        }
    }
}
