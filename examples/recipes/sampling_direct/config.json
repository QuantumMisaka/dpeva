{
    "project": "./",
    "desc_dir": "./desc_pool",
    "testdata_dir": "./other_dpdata",
    
    "fig_dpi": 300,
    "root_savedir": "dpeva_sampling_direct",

    "uq_trust_mode": "no_filter",
    
    "sampler_type": "direct",
    "direct_n_clusters": 50,
    "direct_k": 1,
    "direct_thr_init": 0.5,

    "submission": {
        "backend": "slurm",
        "env_setup": [
            "source /opt/envs/deepmd3.1.2.env",
            "export DP_INTERFACE_PREC=high"
        ],
        "slurm_config": {
            "partition": "CPU-MISC",
            "qos": "rush-cpu",
            "ntasks": 1,
            "cpus_per_task": 4,
            "job_name": "DPEVA-collect"
        }
    }
}
